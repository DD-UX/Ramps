# IDE
.idea/
.vscode/

# Dependencies
node_modules/

# Env
.env
.env.local
.env*.local

# MCP servers — local-only (may grant DB access; never share via git)
.mcp.json

# Build output
.next/
dist/
.turbo/
storybook-static/
coverage/
*.tsbuildinfo

# Playwright — design-system-validate artifacts (regenerated per run)
test-results/
playwright-report/
packages/ui/validation/report/

# Static Storybook served by the web app under /storybook — generated by
# `pnpm --filter @ramps/web build:storybook` (prebuild step), never committed.
apps/web/public/storybook/

# graphify — generated knowledge graph (rebuilt from source via `graphify .`)
graphify-out/

# Next.js auto-generated (recreated on every build)
next-env.d.ts

# Third-party AI skills — materialized from skills-lock.json via `npx skills add`.
# The lockfile is the source of truth (like pnpm-lock.yaml); artifacts are local.
.agents/
.claude/skills/supabase-server

# OS
.DS_Store

# @ramps/web — environment
#
# Copy to `.env.local` (gitignored) and fill in.
#
# Vercel: set each of these under Project → Settings → Environment Variables
# (same names), scoped to Production + Preview + Development as needed. Do NOT
# rely on Vercel's Supabase integration auto-vars — we set these explicitly so
# names stay stable across environments.
#
# Data access is SERVER-ONLY: the Supabase client runs in route handlers /
# server actions via @supabase/server, wrapped by @ramps/sdk. The browser
# never talks to Supabase, so NONE of these use the NEXT_PUBLIC_ prefix
# (that would inline them into the client bundle).

# --- Supabase ---------------------------------------------------------------
# New API key format (sb_publishable_… / sb_secret_…). The legacy anon /
# service_role keys are deprecated and intentionally NOT used here.
#   Local:  values are printed by `supabase start`.
#   Hosted: Supabase → Project → Settings → API keys.

# Project URL.  Local default shown; hosted = https://<ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Publishable key (sb_publishable_…). Client-safe by design, but we still keep
# all access server-side. Resolved by @supabase/server for auth: 'publishable'.
SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_…). FULL access, bypasses RLS. Server-only, NEVER
# NEXT_PUBLIC_. Resolved by @supabase/server for auth: 'secret' / admin client.
# On Vercel, mark this Sensitive so it can't be read back after saving.
SUPABASE_SECRET_KEY=

# JWKS endpoint — verifies Supabase-issued JWTs server-side (auth: 'user').
#   https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# --- App --------------------------------------------------------------------
# Absolute base URL of this app.
#   Local:  http://localhost:3000
#   Vercel: optional — if unset, derive from the auto-provided VERCEL_URL
#           (`https://$VERCEL_URL`). Set explicitly only for a stable prod domain.
APP_URL=http://localhost:3000

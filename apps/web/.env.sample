# @ramps/web — environment
#
# Copy to `.env.local` (gitignored) and fill in. On Vercel, set these as
# Project → Settings → Environment Variables (same names).
#
# Data access is SERVER-ONLY: the Supabase client runs in route handlers /
# server actions, wrapped by @ramps/sdk. The browser never talks to Supabase,
# so none of these are NEXT_PUBLIC_*.

# --- Supabase ---------------------------------------------------------------
# Local:  values are printed by `supabase start`.
# Hosted: Project → Settings → API.

# Project URL (local default shown).
SUPABASE_URL=http://127.0.0.1:54321

# Anon key — safe-ish public key, but we keep it server-side only here.
SUPABASE_ANON_KEY=

# Service-role key — FULL DB access, bypasses RLS. Server-only, NEVER exposed
# to the browser and NEVER prefixed NEXT_PUBLIC_. Required for seed-backed
# server reads/writes the app performs on behalf of the user.
SUPABASE_SERVICE_ROLE_KEY=

# --- App --------------------------------------------------------------------
# Absolute base URL of this app. Local dev = http://localhost:3000.
# On Vercel, use the deployment URL (or leave for Vercel's VERCEL_URL).
APP_URL=http://localhost:3000

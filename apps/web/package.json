{
  "name": "@ramps/web",
  "version": "0.0.0",
  "private": true,
  "description": "Next.js (App Router) app — the payables product surface.",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ramps/ui build && next dev --port 3000",
    "build:storybook": "pnpm --filter @ramps/ui exec storybook build --output-dir ../../apps/web/public/storybook",
    "prebuild": "pnpm build:storybook",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf .next .turbo public/storybook *.tsbuildinfo"
  },
  "dependencies": {
    "@ramps/schemas": "workspace:*",
    "@ramps/sdk": "workspace:*",
    "@ramps/ui": "workspace:*",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.10",
    "@ramps/config": "workspace:*",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.6.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  }
}

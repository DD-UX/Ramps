{
  "name": "@ramps/sdk",
  "version": "0.0.0",
  "private": true,
  "description": "Typed API client — the only place the app calls fetch; every response is parsed with a schema.",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./bills": {
      "types": "./dist/bills.d.ts",
      "import": "./dist/bills.js"
    },
    "./vendors": {
      "types": "./dist/vendors.d.ts",
      "import": "./dist/vendors.js"
    },
    "./bill-tabs": {
      "types": "./dist/bill-tabs.d.ts",
      "import": "./dist/bill-tabs.js"
    },
    "./bill-refs": {
      "types": "./dist/bill-refs.d.ts",
      "import": "./dist/bill-refs.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@ramps/schemas": "workspace:*",
    "@supabase/server": "1.3.0",
    "@supabase/supabase-js": "2.110.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ramps/config": "workspace:*",
    "typescript": "6.0.3"
  }
}

{
  "name": "@ramps/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Ramp design system: verified tokens + components + Storybook workbench.",
  "type": "module",
  "exports": {
    "./tokens.css": "./src/tokens/tokens.css",
    "./theme.css": "./src/tokens/theme.css",
    "./Button": {
      "types": "./dist/components/Button/Button.d.ts",
      "import": "./dist/components/Button/Button.js"
    },
    "./StatusPill": {
      "types": "./dist/components/StatusPill/StatusPill.d.ts",
      "import": "./dist/components/StatusPill/StatusPill.js"
    },
    "./Input": {
      "types": "./dist/components/Input/Input.d.ts",
      "import": "./dist/components/Input/Input.js"
    },
    "./Select": {
      "types": "./dist/components/Select/Select.d.ts",
      "import": "./dist/components/Select/Select.js"
    },
    "./Checkbox": {
      "types": "./dist/components/Checkbox/Checkbox.d.ts",
      "import": "./dist/components/Checkbox/Checkbox.js"
    },
    "./Tabs": {
      "types": "./dist/components/Tabs/Tabs.d.ts",
      "import": "./dist/components/Tabs/Tabs.js"
    },
    "./Tooltip": {
      "types": "./dist/components/Tooltip/Tooltip.d.ts",
      "import": "./dist/components/Tooltip/Tooltip.js"
    },
    "./Toast": {
      "types": "./dist/components/Toast/Toast.d.ts",
      "import": "./dist/components/Toast/Toast.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist .turbo storybook-static *.tsbuildinfo"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@ramps/config": "workspace:*",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  }
}

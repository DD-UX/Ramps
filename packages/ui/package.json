  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "sync:web": "storybook build --output-dir ../../apps/web/public/storybook",
    "validate": "playwright test",
    "validate:gate": "playwright test --project=token-fidelity",
    "validate:advisory": "playwright test --project=visual-advisory",
    "validate:report": "playwright show-report validation/report",
    "clean": "rm -rf dist .turbo storybook-static test-results validation/report *.tsbuildinfo"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "motion": "12.42.2",
    "tailwind-merge": "3.6.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@ramps/config": "workspace:*",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "http-server": "14.1.1",

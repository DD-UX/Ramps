{
  "name": "@ramps/schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Zod schemas — the single source of truth for every model that crosses a boundary.",
  "type": "module",
  "exports": {
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./policies": {
      "types": "./dist/policies.d.ts",
      "import": "./dist/policies.js"
    },
    "./users": {
      "types": "./dist/users.d.ts",
      "import": "./dist/users.js"
    },
    "./vendors": {
      "types": "./dist/vendors.d.ts",
      "import": "./dist/vendors.js"
    },
    "./dimensions": {
      "types": "./dist/dimensions.d.ts",
      "import": "./dist/dimensions.js"
    },
    "./bills": {
      "types": "./dist/bills.d.ts",
      "import": "./dist/bills.js"
    },
    "./approvals": {
      "types": "./dist/approvals.d.ts",
      "import": "./dist/approvals.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "import": "./dist/payments.js"
    },
    "./activity": {
      "types": "./dist/activity.d.ts",
      "import": "./dist/activity.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ramps/config": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
